{
  "name": "electron-builder-ssl-com-esigner",
  "version": "1.0.0-1",
  "type": "module",
  "description": "Electron builder plugin to sign windows executables with SSL.com eSigner",
  "main": "lib/index.mjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "install": "node scripts/download-esigner.js",
    "build": "rimraf lib && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "release": "commit-and-tag-version",
    "release:pre": "commit-and-tag-version --prerelease"
  },
  "files": [
    "scripts/**/*",
    "lib/**/*"
  ],
  "exports": {
    "default": "./lib/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gergof/electron-builder-ssl-com-esigner.git"
  },
  "keywords": [
    "electron",
    "electron-builder",
    "ssl.com",
    "esigner",
    "codesign"
  ],
  "author": "Fandly Gergo <fandly.gergo@fndl.ro>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gergof/electron-builder-ssl-com-esigner/issues"
  },
  "homepage": "https://github.com/gergof/electron-builder-ssl-com-esigner#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "commit-and-tag-version": "^12.7.1",
    "electron-builder": "^26.8.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "env-var": "^7.5.0",
    "fast-glob": "^3.3.3",
    "unzipper": "^0.12.3"
  },
  "peerDependencies": {
    "electron-builder": ">=24.0.0"
  },
  "commit-and-tag-version": {
    "scripts": {
      "prerelease": "git fetch --all --tags"
    },
    "types": [
      {
        "type": "feat",
        "section": "Features"
      },
      {
        "type": "fix",
        "section": "Bug Fixes"
      },
      {
        "type": "imp",
        "section": "Improvements"
      },
      {
        "type": "ci",
        "section": "Build/CI"
      },
      {
        "type": "chore",
        "hidden": true
      },
      {
        "type": "docs",
        "section": "Documentation"
      },
      {
        "type": "refactor",
        "section": "Refactor"
      },
      {
        "type": "test",
        "section": "Testing"
      }
    ]
  }
}
